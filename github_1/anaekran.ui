  <property name="styleSheet">
   <string notr="true">/* --- ANA EKRAN GARANTİ QSS KODLARI --- */

/* Genel Arkaplan */
#dockWidgetContents {
    background-color: #f5f5f5; /* Diğer ekranlarla uyumlu açık gri/krem arkaplan */
}

/* Sol Taraftaki Büyük Menü Butonları */
QPushButton#kitap_inceleme, QPushButton#kitap_islem {
    background-color: #f1e3cd; /* Krem rengi */
    color: #2d4b39; /* Koyu yeşil yazı */
    border: 2px solid #2d4b39; /* Koyu yeşil çerçeve */
    border-radius: 12px; /* Yuvarlak köşeler */
    font-size: 16px;
    font-weight: bold;
}

QPushButton#kitap_inceleme:hover, QPushButton#kitap_islem:hover {
    background-color: #e5d4b8; /* Üzerine gelince biraz koyulaşan krem */
    border: 2px solid #3b604a; /* Çerçeve rengi hafif açılır */
}

/* Sağ Taraftaki Metin Bloğu (textEdit) - Yeşil Tema */
QTextEdit#textEdit {
    background-color: #2d4b39; /* Temanın şık koyu yeşili */
    color: #ffffff; /* Okunabilirlik için beyaz yazı */
    border: 2px solid #603b26; /* Diğer ekranla uyumlu koyu kahverengi çerçeve */
    border-radius: 12px;
    font-size: 15px;
    padding: 15px; /* Yazıların kenarlara yapışmaması için iç boşluk */
}

/* Scrollbar (Kaydırma Çubuğu) Tasarımı (textEdit için) */
QScrollBar:vertical {
    background: #f1e3cd;
    width: 12px;
    margin: 15px 3px 15px 3px;
    border-radius: 4px;
}
QScrollBar::handle:vertical {
    background: #769c80; /* Açık yeşil kaydırma tutamacı */
    min-height: 20px;
    border-radius: 4px;
}
QScrollBar::handle:vertical:hover {
    background: #63866c;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    background: none;
}

/* Progress Bar (Yükleme Çubuğu) Tasarımı */
QProgressBar#progressBar {
    border: 2px solid #2d4b39; /* Koyu yeşil çerçeve */
    background-color: #f1e3cd; /* Krem arkaplan */
    border-radius: 10px; /* Hap şeklinde yuvarlak köşeler */
    text-align: center; /* Yüzde metnini ortalar */
    color: #2d4b39; /* Yüzde yazısı rengi */
    font-weight: bold;
    font-size: 14px;
}

QProgressBar#progressBar::chunk {
    background-color: #769c80; /* Dolum rengi olarak açık yeşil */
    border-radius: 7px; /* Dış çerçeveye uyumlu iç yuvarlaklık */
    margin: 2px; /* Çerçeveye yapışmaması için hafif pay */
}</string>
  </property>
  <property name="windowTitle">
   <string>Dijital Kütüphane</string>
  </property>
  <widget class="QWidget" name="dockWidgetContents">
   <widget class="QProgressBar" name="progressBar">
    <property name="geometry">
