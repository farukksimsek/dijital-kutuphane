    <property name="styleSheet">
     <string notr="true">/* --- ANA EKRAN BÜTÜNLÜK TASARIMI --- */

/* Genel Arkaplan - Açık Krem */
#DIJITALKUTUPHANE &gt; QWidget#dockWidgetContents {
    background-color: #fcf9f2; 
}

/* Kitaplığı İncele ve Kitaplık İşlemleri Butonları (Krem arkaplan, Koyu Yeşil Çerçeve) */
QPushButton#kitap_inceleme, QPushButton#kitap_islem {
    background-color: #f1e3cd; 
    color: #2d4b39; /* Koyu Yeşil Metin */
    border: 2px solid #2d4b39; /* Çerçeve */
    border-radius: 12px;
    font-size: 16px;
    font-weight: bold;
    padding: 10px;
}

/* Butonların Üzerine Gelindiğinde (Hover) */
QPushButton#kitap_inceleme:hover, QPushButton#kitap_islem:hover {
    background-color: #e5d4b8; /* Biraz daha koyu krem */
    border: 2px solid #3b604a;
}

/* --- YENİ PROGRESS BAR TASARIMI --- */
QProgressBar#progressBar {
    border: 2px solid #2d4b39; /* Koyu yeşil dış çerçeve */
    background-color: #f1e3cd; /* İç arkaplan krem */
    border-radius: 12px; /* Tam yuvarlak köşeler */
    text-align: center; /* Yüzde yazısı ortada */
    color: #2d4b39; /* Yazı rengi */
    font-weight: bold;
    font-size: 13px;
}

/* Yüklenen Kısım (Chunk) */
QProgressBar#progressBar::chunk {
    background-color: #769c80; /* Açık yeşil dolum efekti */
    border-radius: 9px; /* Dış çerçeveye uyumlu yuvarlaklık */
    margin: 2px; /* Çerçeve ile dolum arasında şık bir boşluk */
}</string>
