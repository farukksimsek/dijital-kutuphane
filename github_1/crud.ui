    <property name="styleSheet">
     <string notr="true">/* 1. Sadece Ana Arka Plan (Tüm araçları bozmaması için QWidget yerine QMainWindow kullanıyoruz) */
QMainWindow, QDialog {
    background-color: #F4EEDD;
}

/* 2. Etiketler (Labeller kutu gibi durmasın, şeffaf ve şık olsun) */
QLabel {
    color: #3E2723;
    font-family: &quot;Georgia&quot;, serif;
    font-weight: bold;
    font-size: 13px;
    background: transparent;
}

/* 3. GroupBox (Sol taraftaki kapsayıcı kutunun siyah olma hatası düzeltildi) */
QGroupBox {
    background-color: #EFE6CC;
    border: 2px solid #8D6E63;
    border-radius: 6px;
    margin-top: 25px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 15px;
    padding: 0 5px;
    color: #5D4037;
    font-weight: bold;
    font-size: 15px;
    font-style: italic;
    background: transparent;
}

/* 4. Girdi Alanları (Sadece veri girilecek TextBox'lar beyaz kalsın) */
QLineEdit {
    background-color: #FFFFFF;
    border: 1px solid #BCAAA4;
    border-radius: 4px;
    padding: 6px 10px;
    color: #3E2723;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}
QLineEdit:focus {
    border: 2px solid #2E4A35;
    background-color: #FFFAFA;
}

/* 5. Buton (Tamamen izole edildi) */
QPushButton {
    background-color: #2E4A35;
    color: #F4EEDD;
    border: 1px solid #1B2E20;
    border-radius: 4px;
    padding: 8px 15px;
    font-weight: bold;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}
QPushButton:hover {
    background-color: #3C5E45;
}
QPushButton:pressed {
    background-color: #1B2E20;
}

/* 6. Tablo Görünümü ve Başlıklar */
QTableWidget {
    background-color: #FFFFFF;
    alternate-background-color: #F9F6F0;
    border: 1px solid #8D6E63;
    border-radius: 4px;
    gridline-color: #D7CCC8;
    color: #3E2723;
}
QHeaderView::section {
    background-color: #5D4037;
    color: #F4EEDD;
    font-weight: bold;
    padding: 6px;
    border: none;
    border-right: 1px solid #3E2723;
}
QHeaderView {
    background-color: #5D4037;
}</string>
    </property>
