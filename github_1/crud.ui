   <bool>false</bool>
  </property>
  <property name="styleSheet">
   <string notr="true">/* --- CRUD EKRANI BÜTÜNLÜK TASARIMI --- */

/* Genel Arkaplan - Açık Krem */
#DijitalKutuphane &gt; QWidget#dockWidgetContents {
    background-color: #fcf9f2;
}

/* Sol Taraftaki Alan (GroupBox) */
QGroupBox#groupBox {
    background-color: #f1e3cd; /* Krem */
    border: 1px solid #d5c3aa;
    border-radius: 10px;
}

/* Etiketler (Labels) */
QLabel {
    color: #2d4b39; /* Koyu Yeşil */
    font-weight: bold;
    font-size: 12px;
}

/* Metin Giriş Kutuları (LineEdits) */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #769c80; /* Yeşil çerçeve */
    border-radius: 6px;
    padding: 5px;
    color: #333333;
}
QLineEdit:focus {
    border: 2px solid #2d4b39; /* Tıklanınca çerçeve kalınlaşır */
}

/* Ana İşlem Butonları (Koyu Yeşil) */
QPushButton#pushButton, QPushButton#pushButton_2, QPushButton#pushButton_3 {
    background-color: #2d4b39; 
    color: white;
    font-weight: bold;
    border-radius: 6px;
    padding: 10px;
}
QPushButton#pushButton:hover, QPushButton#pushButton_2:hover, QPushButton#pushButton_3:hover {
    background-color: #3b604a; 
}

/* Anasayfaya Geri Dön Butonu (Açık Yeşil) */
QPushButton#geri_don {
    background-color: #769c80; 
    color: white;
    font-weight: bold;
    font-size: 13px;
    border-radius: 8px;
    padding: 10px;
}
QPushButton#geri_don:hover {
    background-color: #63866c;
}

/* Tablo Tasarımı */
QTableWidget#tableWidget {
    background-color: #ffffff;
    alternate-background-color: #f8f6f0; /* Alternatif satır rengi hafif krem */
    gridline-color: #e0e0e0;
    color: #333333;
    border: 1px solid #cccccc;
    border-radius: 5px;
}

/* Tablo Başlıkları (Koyu Yeşil Tema ile uyumlu) */
QHeaderView::section {
    background-color: #2d4b39; /* Başlıklar artık Koyu Yeşil */
    color: white;
    font-weight: bold;
    padding: 6px;
    border: none;
    border-right: 1px solid #3b604a;
}</string>
  </property>
  <property name="windowTitle">
   <string>Dijital Kütüphane</string>
  </property>
