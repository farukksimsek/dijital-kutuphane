  <property name="styleSheet">
   <string notr="true">/* --- KİTAPLIK EKRANI BÜTÜNLÜK TASARIMI --- */

/* Genel Arkaplan - Açık Krem */
#DockWidget &gt; QWidget#dockWidgetContents {
    background-color: #fcf9f2;
}

/* Ana Sayfaya Geri Dön Butonu (Diğer ekranla aynı) */
QPushButton#geri_don_2 {
    background-color: #769c80; 
    color: white;
    font-weight: bold;
    font-size: 13px;
    border: none;
    border-radius: 8px;
    padding: 10px;
}
QPushButton#geri_don_2:hover {
    background-color: #63866c;
}

/* Krem/Yeşil Temalı Tablo (Diğer ekranla aynı) */
QTableWidget#tableWidget {
    background-color: #ffffff;
    alternate-background-color: #f8f6f0; 
    gridline-color: #e0e0e0;
    color: #333333;
    border: 1px solid #cccccc;
    border-radius: 5px;
    selection-background-color: #769c80; /* Satır seçildiğinde açık yeşil olur */
    selection-color: white;
}

/* Tablo Başlıkları */
QHeaderView::section {
    background-color: #2d4b39; 
    color: white;
    font-weight: bold;
    padding: 6px;
    border: none;
    border-right: 1px solid #3b604a;
}</string>
